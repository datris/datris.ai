---
---

<footer class="footer">
  <div class="container footer-inner">
    <div class="footer-brand">
      <a href="/" class="footer-logo">
        <svg width="24" height="24" viewBox="0 0 32 32" fill="none">
          <rect width="32" height="32" rx="8" fill="url(#footer-logo-grad)" />
          <path d="M8 10h6l4 6-4 6H8l4-6-4-6z" fill="#0a0e1a" />
          <path d="M16 10h6l4 6-4 6h-6l4-6-4-6z" fill="#0a0e1a" opacity="0.6" />
          <defs>
            <linearGradient id="footer-logo-grad" x1="0" y1="0" x2="32" y2="32">
              <stop stop-color="#00b4ff" />
              <stop offset="1" stop-color="#00e5a0" />
            </linearGradient>
          </defs>
        </svg>
        <span>Datris<span class="footer-dot">.ai</span></span>
      </a>
      <p class="footer-tagline">The AI-Native Data Pipeline</p>
    </div>

    <div class="footer-links">
      <a href="/case-studies" class="footer-link">Case Studies</a>
      <a href="/about" class="footer-link">About</a>
      <a href="/blog" class="footer-link">Blog</a>
      <a
        href="https://github.com/datris/datris-platform-oss"
        target="_blank"
        rel="noopener"
        class="footer-link"
      >
        <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
        GitHub
      </a>
    </div>

    <div class="footer-bottom">
      <p>&copy; 2026 Datris.ai. Built by <a href="https://datris.ai">Datris.ai</a>.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--border-color);
    padding: 64px 0 40px;
  }

  .footer-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
    text-align: center;
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-weight: 700;
    font-size: 1rem;
  }

  .footer-dot {
    color: var(--accent);
  }

  .footer-tagline {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-top: 8px;
  }

  .footer-links {
    display: flex;
    gap: 24px;
  }

  .footer-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.85rem;
    color: var(--text-secondary);
    transition: color var(--transition-fast);
  }

  .footer-link:hover {
    color: var(--text-primary);
  }

  .footer-bottom {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .footer-bottom a {
    color: var(--text-secondary);
    transition: color var(--transition-fast);
  }

  .footer-bottom a:hover {
    color: var(--accent);
  }
</style>
