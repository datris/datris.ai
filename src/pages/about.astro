---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="About — Datris.ai" description="Meet the team behind Datris.ai — the first AI agent-native data platform. 25+ years building enterprise data infrastructure for Fortune 500 firms.">
  <Nav />
  <main>
    <!-- Hero -->
    <section class="about-hero">
      <div class="bg-grid"></div>
      <div class="bg-glow" style="top: -200px; left: 50%; transform: translateX(-50%); background: var(--accent);"></div>
      <div class="container">
        <span class="section-label">About Us</span>
        <h1 class="section-title">Built by practitioners,<br /><span class="gradient-text">not theorists</span></h1>
        <p class="section-subtitle">
          Datris.ai was founded by enterprise data architects who spent decades building data infrastructure 
          at the world's largest financial institutions. We know what breaks at scale — because we've fixed it.
        </p>
      </div>
    </section>

    <hr class="section-divider" />

    <!-- Company Story -->
    <section class="about-story">
      <div class="container">
        <span class="section-label">Our Story</span>
        <h2 class="section-title">From Wall Street to <span class="gradient-text">AI-native</span></h2>
        <div class="story-content">
          <p>
            Datris.ai (formerly IData Corporation, founded 1996) has spent nearly three decades helping 
            enterprises wrangle their data. From Goldman Sachs trading floors to pension funds managing 
            $200B+ in assets, we've built the pipelines that move the world's most critical data.
          </p>
          <p>
            In 2026, we rebranded to Datris.ai and open-sourced our platform — because we believe AI agents 
            need first-class access to enterprise data infrastructure. Not through brittle integrations or 
            wrapper APIs, but natively, through the Model Context Protocol (MCP).
          </p>
          <p>
            The result is the first data platform where AI agents can autonomously build pipelines, ingest 
            documents, validate data quality, search vector databases, and query structured data — all 
            without writing integration code.
          </p>
        </div>
      </div>
    </section>

    <hr class="section-divider" />

    <!-- Leadership -->
    <section id="leadership" class="about-leadership">
      <div class="container">
        <span class="section-label">Leadership</span>
        <h2 class="section-title">The team behind <span class="gradient-text">Datris.ai</span></h2>
        <p class="section-subtitle">Decades of experience building and deploying enterprise data solutions at Fortune 500 firms.</p>

        <div class="leaders-grid">
          <!-- Todd -->
          <div class="leader-card card">
            <div class="leader-avatar">TF</div>
            <h3 class="leader-name">Todd Fearn</h3>
            <p class="leader-title">Founder & CEO</p>
            <div class="leader-bio">
              <p>
                35+ years building data infrastructure and software for financial services — from PC Assembly 
                at Goldman Sachs in 1989 to AI-native data platforms today. Deep expertise as a cloud architect 
                (AWS since 2007) and hands-on software developer across Python, Scala, Java, C, C++, and more.
              </p>
              <p>
                Prior to Datris, Todd served as Acting Head of Cloud Compute at one of the world's largest 
                pension funds, Senior Software Engineer at Bridgewater Associates, and Chief Architect at 
                Deutsche Bank. He has also founded and led several venture-backed startups including REV 
                Entertainment (backed by Warner Music, Elektra, and Atlantic Records) and Code360/Adaptinet.
              </p>
            </div>
            <div class="leader-highlights">
              <span class="highlight-tag">Goldman Sachs</span>
              <span class="highlight-tag">Bridgewater</span>
              <span class="highlight-tag">Deutsche Bank</span>
              <span class="highlight-tag">Freddie Mac</span>
              <span class="highlight-tag">AWS since 2007</span>
            </div>
            <div class="leader-links">
              <a href="https://www.linkedin.com/in/toddfearn/" target="_blank" rel="noopener" class="leader-link">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
                LinkedIn
              </a>
            </div>
          </div>

          <!-- Shawn -->
          <div class="leader-card card">
            <div class="leader-avatar">SB</div>
            <h3 class="leader-name">Shawn Bardong</h3>
            <p class="leader-title">Managing Partner</p>
            <div class="leader-bio">
              <p>
                30+ years leading teams across trading, data & analytics, and technology. A product 
                management expert with over two decades of new product delivery across the global 
                financial services industry, with deep expertise in financial asset analytics and valuation, 
                automated execution services, market structure, and compliance.
              </p>
              <p>
                Significant roles at Morgan Stanley include MD/Head of Trading (Japan), MD/Pan-Asian CTO 
                for Investment Bank, and Global COO for Strategies & Modeling. Also served as COO for Arxis 
                Capital Group, a global equity & ETF automated market-making startup. AWS certified Cloud 
                Practitioner. BA in Economics from Hobart College.
              </p>
            </div>
            <div class="leader-highlights">
              <span class="highlight-tag">Morgan Stanley</span>
              <span class="highlight-tag">MD/Head of Trading</span>
              <span class="highlight-tag">Pan-Asian CTO</span>
              <span class="highlight-tag">AWS Certified</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <hr class="section-divider" />

    <!-- Clients -->
    <section class="about-clients">
      <div class="container">
        <span class="section-label">Track Record</span>
        <h2 class="section-title">Trusted by the world's<br /><span class="gradient-text">leading institutions</span></h2>
        <p class="section-subtitle">
          Our team has built and deployed data solutions at some of the most demanding organizations in finance.
        </p>
        <div class="clients-grid">
          <div class="client-item">Goldman Sachs</div>
          <div class="client-item">Bridgewater Associates</div>
          <div class="client-item">Deutsche Bank</div>
          <div class="client-item">Morgan Stanley</div>
          <div class="client-item">Bank of America</div>
          <div class="client-item">JP Morgan</div>
          <div class="client-item">UBS</div>
          <div class="client-item">Credit Suisse</div>
          <div class="client-item">Citibank</div>
          <div class="client-item">Freddie Mac</div>
        </div>
      </div>
    </section>

    <hr class="section-divider" />

    <!-- CTA -->
    <section class="about-cta">
      <div class="container" style="text-align: center;">
        <h2 class="section-title">Ready to modernize your <span class="gradient-text">data pipeline</span>?</h2>
        <p class="section-subtitle" style="margin: 0 auto 32px;">
          Open source. Self-hosted. AI-native from day one.
        </p>
        <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap;">
          <a href="https://github.com/datris/datris-platform-oss" target="_blank" rel="noopener" class="btn btn-primary">
            <svg width="18" height="18" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
            Get Started on GitHub
          </a>
          <a href="/case-studies" class="btn btn-secondary">View Case Studies →</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .about-hero {
    padding: 160px 0 80px;
    position: relative;
    overflow: hidden;
  }

  .about-story .story-content {
    max-width: 800px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-top: 32px;
  }

  .about-story .story-content p {
    font-size: 1.05rem;
    color: var(--text-secondary);
    line-height: 1.8;
  }

  .leaders-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 32px;
    margin-top: 48px;
  }

  .leader-card {
    padding: 40px;
  }

  .leader-avatar {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: var(--gradient);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
    font-size: 1.2rem;
    color: #0a0e1a;
    margin-bottom: 20px;
  }

  .leader-name {
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  .leader-title {
    font-size: 0.9rem;
    color: var(--accent);
    font-weight: 500;
    margin-top: 4px;
    margin-bottom: 20px;
  }

  .leader-bio {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 20px;
  }

  .leader-bio p {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.7;
  }

  .leader-highlights {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 20px;
  }

  .highlight-tag {
    padding: 4px 12px;
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 500;
    background: rgba(0, 180, 255, 0.08);
    border: 1px solid rgba(0, 180, 255, 0.15);
    color: var(--accent);
  }

  .leader-links {
    display: flex;
    gap: 16px;
  }

  .leader-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-size: 0.85rem;
    color: var(--text-secondary);
    transition: color var(--transition-fast);
  }

  .leader-link:hover {
    color: var(--accent);
  }

  .clients-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 16px;
    margin-top: 48px;
  }

  .client-item {
    padding: 20px 16px;
    text-align: center;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--text-secondary);
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    transition: border-color var(--transition-base), color var(--transition-base);
  }

  .client-item:hover {
    border-color: var(--border-color-hover);
    color: var(--text-primary);
  }

  .about-cta {
    padding: 100px 0;
  }

  @media (max-width: 1024px) {
    .clients-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .leaders-grid {
      grid-template-columns: 1fr;
    }

    .clients-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .about-hero {
      padding: 120px 0 60px;
    }
  }
</style>
