---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Privacy Policy — Datris.ai" description="Privacy policy for datris.ai">
  <Nav />
  <main class="privacy-page">
    <div class="container">
      <h1>Privacy Policy</h1>
      <p class="last-updated">Last updated: March 29, 2026</p>

      <h2>Overview</h2>
      <p>Datris.ai ("we", "us", "our") operates the datris.ai website. This page informs you of our policies regarding the collection, use, and disclosure of information when you visit our site.</p>

      <h2>Information We Collect</h2>
      <h3>Analytics</h3>
      <p>We use Google Analytics to collect anonymous usage data, including:</p>
      <ul>
        <li>Pages visited and time spent on each page</li>
        <li>Referring website or source</li>
        <li>Browser type and device information</li>
        <li>Approximate geographic location (country/region level)</li>
      </ul>
      <p>Google Analytics uses cookies to distinguish unique users. This data is aggregated and does not personally identify you. You can opt out of Google Analytics by installing the <a href="https://tools.google.com/dlpage/gaoptout" target="_blank" rel="noopener">Google Analytics Opt-out Browser Add-on</a>.</p>

      <h3>Personal Information</h3>
      <p>We do not collect personal information such as names, email addresses, or payment details through this website.</p>

      <h2>Cookies</h2>
      <p>This site uses cookies solely for Google Analytics. No advertising or tracking cookies are used beyond analytics.</p>

      <h2>Third-Party Services</h2>
      <p>This website is hosted on GitHub Pages. Please refer to <a href="https://docs.github.com/en/site-policy/privacy-policies/github-general-privacy-statement" target="_blank" rel="noopener">GitHub's Privacy Statement</a> for their data handling practices.</p>

      <h2>Open Source Software</h2>
      <p>Datris is an open-source project hosted on <a href="https://github.com/datris/datris-platform-oss" target="_blank" rel="noopener">GitHub</a>. Any data you process through the self-hosted Datris platform runs entirely on your own infrastructure. We have no access to your data.</p>

      <h2>Changes to This Policy</h2>
      <p>We may update this privacy policy from time to time. Changes will be posted on this page with an updated date.</p>

      <h2>Contact</h2>
      <p>If you have questions about this privacy policy, please open an issue on our <a href="https://github.com/datris/datris-platform-oss" target="_blank" rel="noopener">GitHub repository</a>.</p>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .privacy-page {
    padding: 120px 0 80px;
    max-width: 720px;
    margin: 0 auto;
  }

  h1 {
    font-size: 2.5rem;
    font-weight: 800;
    margin-bottom: 8px;
  }

  .last-updated {
    color: var(--text-muted);
    font-size: 0.85rem;
    margin-bottom: 48px;
  }

  h2 {
    font-size: 1.25rem;
    font-weight: 700;
    margin-top: 36px;
    margin-bottom: 12px;
  }

  h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-top: 20px;
    margin-bottom: 8px;
  }

  p, li {
    color: var(--text-secondary);
    line-height: 1.7;
    font-size: 0.95rem;
  }

  ul {
    padding-left: 24px;
    margin: 8px 0;
  }

  li {
    margin-bottom: 4px;
  }

  a {
    color: var(--accent);
    transition: color var(--transition-fast);
  }

  a:hover {
    color: var(--accent-secondary);
  }
</style>
