---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import AIFeatures from '../components/AIFeatures.astro';
import Architecture from '../components/Architecture.astro';
import VectorDB from '../components/VectorDB.astro';
import MCP from '../components/MCP.astro';
import Formats from '../components/Formats.astro';
import Providers from '../components/Providers.astro';
import Infrastructure from '../components/Infrastructure.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Nav />
  <main>
    <Hero />
    <hr class="section-divider" />
    <AIFeatures />
    <hr class="section-divider" />
    <Architecture />
    <hr class="section-divider" />
    <VectorDB />
    <hr class="section-divider" />
    <MCP />
    <hr class="section-divider" />
    <Formats />
    <hr class="section-divider" />
    <Providers />
    <hr class="section-divider" />
    <Infrastructure />
  </main>
  <Footer />
</Layout>
