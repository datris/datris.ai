---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Layout title="Blog — Datris.ai" description="Insights on AI agent-native data platforms, MCP, RAG pipelines, and modern data engineering.">
  <Nav />
  <main>
    <section class="blog-hero">
      <div class="bg-grid"></div>
      <div class="bg-glow blog-glow-1"></div>
      <div class="container">
        <div class="section-label">Blog</div>
        <h1 class="section-title">Insights & Engineering</h1>
        <p class="section-subtitle">
          AI agents, data platforms, MCP, RAG pipelines — what we're building and what we're learning.
        </p>
      </div>
    </section>

    <section class="blog-list">
      <div class="container">
        {posts.length === 0 ? (
          <p class="no-posts">No posts yet. Check back soon.</p>
        ) : (
          <div class="posts-grid">
            {posts.map((post) => (
              <a href={`/blog/${post.id}`} class="post-card card">
                <div class="post-meta">
                  <time datetime={post.data.date}>
                    {new Date(post.data.date).toLocaleDateString('en-US', {
                      year: 'numeric',
                      month: 'long',
                      day: 'numeric',
                    })}
                  </time>
                  {post.data.tags.length > 0 && (
                    <div class="post-tags">
                      {post.data.tags.slice(0, 3).map((tag) => (
                        <span class="post-tag">{tag}</span>
                      ))}
                    </div>
                  )}
                </div>
                <h2 class="post-title">{post.data.title}</h2>
                <p class="post-description">{post.data.description}</p>
                <span class="read-more">
                  Read more
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17l9.2-9.2M17 17V8H8"/></svg>
                </span>
              </a>
            ))}
          </div>
        )}
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .blog-hero {
    padding: 160px 0 60px;
    position: relative;
    overflow: hidden;
  }

  .blog-glow-1 {
    background: radial-gradient(circle, rgba(0, 180, 255, 0.15), transparent 70%);
    top: -200px;
    left: 30%;
    transform: translateX(-50%);
  }

  .blog-list {
    padding: 40px 0 120px;
  }

  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    gap: 24px;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    cursor: pointer;
  }

  .post-card:hover .post-title {
    color: var(--accent);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }

  .post-meta time {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .post-tags {
    display: flex;
    gap: 6px;
  }

  .post-tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    padding: 2px 8px;
    border-radius: 100px;
    background: rgba(0, 229, 160, 0.08);
    border: 1px solid rgba(0, 229, 160, 0.2);
    color: var(--accent-secondary);
  }

  .post-title {
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin-bottom: 10px;
    transition: color var(--transition-fast);
  }

  .post-description {
    font-size: 0.9rem;
    color: var(--text-secondary);
    line-height: 1.6;
    margin-bottom: 16px;
    flex: 1;
  }

  .read-more {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--accent);
  }

  .no-posts {
    text-align: center;
    color: var(--text-muted);
    padding: 60px 0;
    font-size: 1.1rem;
  }

  @media (max-width: 768px) {
    .blog-hero {
      padding: 120px 0 40px;
    }

    .posts-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
